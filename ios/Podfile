# ios/Podfile
platform :ios, '13.0'

# Flutter generated pod helpers
# This file is generated by 'flutter pub get' on a Mac.
# On Windows, it won't exist, but it will be generated during the Codemagic build.
generated_pod_helpers = File.expand_path(File.join('..', 'Flutter', 'generated_pod_helpers.rb'), __FILE__)

if File.exist?(generated_pod_helpers)
  require generated_pod_helpers
else
  # If the file doesn't exist yet, we define empty methods to allow Podfile parsing.
  # Codemagic will run 'flutter pub get' which should generate this file on a Mac.
  def flutter_install_all_ios_pods(path); end
  def flutter_additional_ios_build_settings(target); end
end

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.expand_path(File.join('..', 'Flutter'), __FILE__)
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      config.build_settings['ENABLE_BITCODE'] = 'NO'
    end
  end
end
